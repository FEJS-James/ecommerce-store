# Site URL (used for canonical URLs, OG meta — set to your production domain)
NEXT_PUBLIC_SITE_URL=https://aiarmory.shop

# Admin Authentication
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@store.local
JWT_SECRET=your-jwt-secret-here

# Stripe (optional — store works without these)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Turso (optional — uses local SQLite by default)
TURSO_ECOMMERCE_DATABASE_URL=
TURSO_ECOMMERCE_AUTH_TOKEN=

NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is
