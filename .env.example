# Site URL (used for canonical URLs, OG meta — set to your production domain)
NEXT_PUBLIC_SITE_URL=https://aiarmory.shop

# Admin Authentication
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@store.local
JWT_SECRET=your-jwt-secret-here

# Stripe (optional — store works without these)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Turso (optional — uses local SQLite by default)
TURSO_ECOMMERCE_DATABASE_URL=
TURSO_ECOMMERCE_AUTH_TOKEN=

NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is

# BTCPay Server (optional — crypto payments)
BTCPAY_URL=
BTCPAY_STORE_ID=
BTCPAY_API_KEY=
BTCPAY_WEBHOOK_SECRET=

# PayPal (optional -- set in Vercel project settings for production)
# Note: NEXT_PUBLIC_* vars are inlined at build time in Next.js client code.
# The PayPal button also fetches this at runtime via /api/config/paypal as a
# fallback, so it works even if the var is added after deployment.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Resend (email delivery)
RESEND_API_KEY=
EMAIL_FROM=support@aiarmory.shop
